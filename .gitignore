# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# ──────────────────────────────────────────────────────────────
# Local env files (keep the .env.example templates tracked)
# ──────────────────────────────────────────────────────────────
.env
**/.env

# ──────────────────────────────────────────────────────────────
# Node / Angular / Nest (backend/ and frontend/)
# ──────────────────────────────────────────────────────────────
node_modules/
dist/
release/
*.tsbuildinfo
.angular/
npm-debug.log*
yarn-error.log*

