{
  "name": "ez-money-desktop",
  "version": "0.2.1",
  "private": true,
  "author": "hazeliscoding",
  "license": "Apache-2.0",
  "description": "ez-money desktop app (Electron) — import Chime statements, track budgets, all local.",
  "main": "dist/main/main/main.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parser": "tsx src/main/core/parser/golden-test.ts",
    "test:db": "tsx src/main/core/db-test.ts",
    "build:main": "tsc -p tsconfig.json",
    "start": "electron .",
    "smoke": "electron dist/main/main/smoke.js",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "pdfjs-dist": "4.7.76",
    "reflect-metadata": "^0.2.2",
    "sql.js": "^1.14.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.ezmoney.app",
    "productName": "ez-money",
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "hazeliscoding",
      "repo": "ez-money"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.png",
      "package.json",
      "!**/node_modules/canvas/**"
    ],
    "asarUnpack": [
      "**/*.wasm",
      "build/icon.png"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Finance",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
